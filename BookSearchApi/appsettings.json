{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "BookSearchApi",
    "Audience": "BookSearchApiUsers"
  },
  "OpenLibrary": {
    "BaseUrl": "https://openlibrary.org"
  },
  "Gemini": {
    "BaseUrl": "https://generativelanguage.googleapis.com"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:5000"
      },
      "Https": {
        "Url": "https://+:5001"
      }
    }
  }
}